{% extends '_layout.html.twig' %}

{% block content %}
<h1 style="margin:0 0 16px;font-size:22px;font-weight:600;color:#15131D;">
  Recurring invoice draft will be issued soon
</h1>

<p style="margin:0 0 12px;">Hello,</p>

<p style="margin:0 0 16px;">
  the recurring invoice draft <strong>{{ template_name }}</strong>{% if client_name %} for <strong>{{ client_name }}</strong>{% endif %}
  will be issued automatically on <strong style="color:#C2410C;">{{ issue_date|date('j M Y') }}</strong>.
  If you want to add extra work to the work report, please do so before then.
</p>

<table role="presentation" cellpadding="0" cellspacing="0" style="width:100%;border-collapse:collapse;background:#F4F2FA;border:1px solid #D9D3EC;border-radius:8px;margin:16px 0;">
  <tr>
    <td style="padding:16px 20px;">
      <table role="presentation" cellpadding="0" cellspacing="0" style="width:100%;font-size:14px;color:#403B52;">
        <tr>
          <td style="padding:4px 0;color:#7A748C;width:48%;">Issue date</td>
          <td style="padding:4px 0;font-weight:600;color:#15131D;">{{ issue_date|date('j M Y') }}</td>
        </tr>
        <tr>
          <td style="padding:4px 0;color:#7A748C;">Work report items (extra work)</td>
          <td style="padding:4px 0;font-weight:600;color:#15131D;">{{ work_item_count }}</td>
        </tr>
        <tr>
          <td style="padding:8px 0 0;color:#7A748C;border-top:1px solid #D9D3EC;">Current amount due</td>
          <td style="padding:8px 0 0;border-top:1px solid #D9D3EC;font-size:18px;font-weight:700;color:#3B2D83;font-family:monospace;">
            {{ amount_to_pay|number_format(2, ',', ' ') }} {{ invoice.currency }}
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>

{% if edit_link %}
<table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:24px 0 8px;">
  <tr>
    <td style="border-radius:8px;background:#3B2D83;">
      <a href="{{ edit_link }}" style="display:inline-block;padding:12px 24px;font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;border-radius:8px;">
        Open draft and edit work report
      </a>
    </td>
  </tr>
</table>
{% endif %}

<p style="margin:24px 0 0;font-size:13px;color:#7A748C;">
  If you add nothing, the invoice will be issued with its current contents.
</p>
{% endblock %}
